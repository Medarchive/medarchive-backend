NODE_ENV=development
APP_PORT=9090
DATABASE_URL=postgresql://postgres:password@localhost:5432/medarchive
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-super-secret-refresh-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

API_KEY_SECRET=change-me-api-key-secret-min-32-chars-here

RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-bucket-name
